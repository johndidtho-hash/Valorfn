# ─── Discord ──────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Application (client) ID from the Discord developer portal
DISCORD_CLIENT_ID=your_discord_client_id_here

# Guild ID for guild-scoped command registration during development (optional)
DISCORD_GUILD_ID=your_discord_guild_id_here

# ─── Epic Games OAuth ─────────────────────────────────────────────────────────
# Client ID from https://dev.epicgames.com/portal
EPIC_CLIENT_ID=your_epic_client_id_here

# Client secret from the Epic Games developer portal
EPIC_CLIENT_SECRET=your_epic_client_secret_here

# Full public URL of this service — used as the OAuth redirect URI
# Must be registered in the Epic Games developer portal
# Example: https://valorfn.example.com
BASE_URL=http://localhost:3000

# ─── Fortnite API ─────────────────────────────────────────────────────────────
# API key from https://fortniteapi.io  (or your preferred Fortnite stats provider)
FORTNITE_API_KEY=your_fortnite_api_key_here

# ─── Security ─────────────────────────────────────────────────────────────────
# 32-byte hex string used to AES-256 encrypt stored OAuth tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
